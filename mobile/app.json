{
  "expo": {
    "name": "App mobile",
    "slug": "app-mobile",
    "version": "0.1.1",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "androidStatusBar": {
      "backgroundColor": "#000000",
      "barStyle": "light-content"
    },
    "androidNavigationBar": {
      "backgroundColor": "#000000",
      "barStyle": "light-content"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "package": "com.sistema.mobile",
      "permissions": [
        "CAMERA"
      ],
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.SYSTEM_ALERT_WINDOW"
      ]
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sistema.mobile",
      "infoPlist": {
        "NSCameraUsageDescription": "O app usa a camera para registrar fotos dos atendimentos."
      }
    },
    "plugins": [
      "expo-sqlite",
      [
        "expo-camera",
        {
          "cameraPermission": "Permitir que o app registre fotos dos atendimentos."
        }
      ],
      "expo-font",
      "expo-asset",
      "expo-local-authentication"
    ]
  }
}
